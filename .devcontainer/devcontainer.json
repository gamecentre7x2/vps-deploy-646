{
  "name": "VPS V8",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "postCreateCommand": "bash .devcontainer/setup.sh",
  "forwardPorts": [
    5000
  ],
  "portsAttributes": {
    "5000": {
      "label": "API",
      "visibility": "public",
      "onAutoForward": "openBrowser"
    }
  }
}